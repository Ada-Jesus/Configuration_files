{
  "containerDefinitions": [
    {
      "name": "aspnet-api",
      "image": "627119595303.dkr.ecr.us-east-1.amazonaws.com/aspnet-api-production:v2",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "production"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aspnet-api-production",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ],
  "family": "aspnet-api-production",
  "taskRoleArn": "arn:aws:iam::627119595303:role/aspnet-api-production-task-role",
  "executionRoleArn": "arn:aws:iam::627119595303:role/aspnet-api-production-task-execution-role",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024"
}
